# ============================================================
# 这部分为你自己电脑上面的敏感数据示例，你应该新建一个.env(就叫这个名字)然后按下面的格式写，.gitignore已经帮你把这个排除了不会提交到GitHub上
# 大数据分析实践 — 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================================

# ---------- API 密钥 ----------
# 飞书开放平台
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 其他第三方 API（按需添加）
# OPENAI_API_KEY=sk-xxxxxxxx
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_kaggle_key

# ---------- 数据库 ----------
# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=bigdata_analysis

# ---------- 项目路径 ----------
PROJECT_ROOT=.
DATA_DIR=./data
OUTPUT_DIR=./output

# ---------- Jupyter ----------
JUPYTER_PORT=8888
JUPYTER_TOKEN=your_token_here

# ---------- 其他配置 ----------
# 调试模式
DEBUG=true
LOG_LEVEL=INFO
